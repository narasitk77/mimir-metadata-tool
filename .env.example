# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8765

# ── Mimir ─────────────────────────────────────────────────────────────────────
MIMIR_BASE_URL=https://apac.mjoll.no
# Static token (expires ~1h) — ปล่อยว่างถ้าใช้ Cognito SRP ด้านล่าง
MIMIR_TOKEN=
# Cognito SRP (auto-refresh ทุก 55 นาที — แนะนำ)
MIMIR_COGNITO_USER_POOL_ID=
MIMIR_COGNITO_CLIENT_ID=
MIMIR_USERNAME=
MIMIR_PASSWORD=
FOLDER_ID=your_folder_id_here

# ── AI provider (Gemini only) ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Processing ────────────────────────────────────────────────────────────────
ITEMS_PER_PAGE=100
GEMINI_DELAY_MS=7000
BATCH_SIZE=20

# ── Postgres (สำหรับ docker-compose Portainer) ────────────────────────────────
POSTGRES_DB=mimir_metadata
POSTGRES_USER=mimir
POSTGRES_PASSWORD=mimir_secret

# ── Google SSO gate (จำกัดเฉพาะ @thestandard.co) ──────────────────────────────
# 1. ไปที่ https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Application type: Web application
# 3. Authorized redirect URI ต้องตรงกับ GOOGLE_AUTH_REDIRECT_URI ด้านล่างเป๊ะ
# 4. SESSION_SECRET_KEY สุ่มเอง: python -c "import secrets;print(secrets.token_urlsafe(32))"
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://192.168.21.220:8765/auth/callback
ALLOWED_EMAIL_DOMAIN=thestandard.co
SESSION_SECRET_KEY=
