# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8765

# ── Mimir DAM ─────────────────────────────────────────────────────────────────
MIMIR_BASE_URL=https://apac.mjoll.no
# Pick one of:
#   1. Static token (copy from a logged-in browser session, expires ~1h)
MIMIR_TOKEN=
#   2. Cognito SRP auth (auto-refresh every 55 min — recommended)
MIMIR_COGNITO_USER_POOL_ID=
MIMIR_COGNITO_CLIENT_ID=
MIMIR_USERNAME=
MIMIR_PASSWORD=

# Optional: default folder to scan
FOLDER_ID=

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Postgres (for docker-compose) ─────────────────────────────────────────────
POSTGRES_DB=mimir_metadata
POSTGRES_USER=mimir
POSTGRES_PASSWORD=mimir_secret

# ── Processing rate ───────────────────────────────────────────────────────────
ITEMS_PER_PAGE=100
GEMINI_DELAY_MS=7000   # 7s = ~8 req/min, below free-tier 10 RPM
BATCH_SIZE=20

# ── Automation scheduler ──────────────────────────────────────────────────────
AUTOMATION_POLL_INTERVAL_MINUTES=15  # poll watch folders every N minutes (default 15)
AUTOMATION_DAILY_HOUR=2              # UTC hour for daily sweep (0-23, default 2 = 2 AM UTC = 9 AM TH)
AUTOMATION_DAILY_MINUTE=0            # minute offset for daily sweep
AUTOMATION_DAILY_WARN_USD=5.0        # warn if daily Gemini spend exceeds this (USD)

# ── External scheduler mode (n8n) — see n8n/README.md ────────────────────────
AUTOMATION_SCHEDULER_ENABLED=true    # false = n8n owns the schedule (internal APScheduler off)
AUTOMATION_API_KEY=                  # openssl rand -hex 24 — enables X-API-Key bypass for /api/*
DISCORD_WEBHOOK_URL_N8N=             # webhook used by n8n (keep DISCORD_WEBHOOK_URL empty in n8n mode)

# ── Discord notifications (optional) ──────────────────────────────────────────
# Leave blank to disable. Create webhook: Discord → Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
APP_BASE_URL=http://YOUR_SERVER_IP:8765  # shown as link inside the Discord message
