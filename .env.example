# ── Mimir ─────────────────────────────────────────────────────────────────────
MIMIR_BASE_URL=https://apac.mjoll.no
MIMIR_TOKEN=your_mimir_token_here
FOLDER_ID=your_folder_id_here

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Processing ────────────────────────────────────────────────────────────────
ITEMS_PER_PAGE=100
GEMINI_DELAY_MS=4500
BATCH_SIZE=20

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8000
