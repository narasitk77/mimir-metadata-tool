{
  "name": "มีมี่ — Mimir Chat Agent",
  "nodes": [
    {
      "parameters": {
        "public": true,
        "options": {
          "title": "มีมี่ 🎬",
          "subtitle": "ผู้ดูแลคลังภาพ The Standard",
